{
  "name": "hrmn-soccer-data-provider",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run env:dev && ng serve",
    "build": "npm run env:prod && ng build",
    "watch": "npm run env:dev && ng build --watch --configuration development",
    "test": "npm run env:test && ng test",
    "env:dev": "node ./scripts/sync-env.mjs development",
    "env:prod": "node ./scripts/sync-env.mjs production",
    "env:test": "node ./scripts/sync-env.mjs test"
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/animations": "^22.0.7",
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.5",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@tailwindcss/postcss": "^4.3.3",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.21",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
